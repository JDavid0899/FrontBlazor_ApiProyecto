@page "/area_conoc"
@rendermode InteractiveServer
@inject FrontBlazor_ApiProyecto.Services.ApiService Api

<PageTitle>Areas de Conocimiento</PageTitle>

<div class="container mt-4">
    <h3>Areas</h3>

    @* ───────── ALERTA ───────── *@
    @if (!string.IsNullOrEmpty(mensaje))
    {
        <div class="alert @(exito ? "alert-success" : "alert-danger") alert-dismissible fade show">
            @mensaje
            <button type="button" class="btn-close" @onclick="() => mensaje = string.Empty"></button>
        </div>
    }

    @* ───────── BOTON NUEVO ───────── *@
    @if (!mostrarFormulario)
    {
        <button class="btn btn-primary mb-3" @onclick="NuevoRegistro">Nueva Area</button>
    }

    @* ───────── LIMITE DE REGISTROS ───────── *@
    <div class="d-flex align-items-center mb-3">
        <label class="form-label me-2 mb-0">Limite:</label>
        <input class="form-control me-2" type="number" style="width:100px" @bind="limite" />
        <button class="btn btn-outline-secondary" @onclick="CargarRegistros">Cargar</button>
    </div>

    @* ───────── FORMULARIO ───────── *@
    @if (mostrarFormulario)
    {
        <div class="card mb-3">
            <div class="card-header">
                @(editando ? "Editar Area" : "Nueva Area")
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Codigo</label>
                        <input class="form-control" @bind="campoCodigo" disabled="@editando" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Gran Area</label>
                        <input class="form-control" @bind="campoGran" />
                    </div>
                    <div class="col-md-4 mb-3">
                        <label class="form-label">Area</label>
                        <input class="form-control" @bind="campoArea" />
                    </div>
                    <div class="col-md-3 mb-3">
                        <label class="form-label">Disciplina</label>
                        <input class="form-control" @bind="campoDisc" />
                    </div>
                </div>
                <button class="btn btn-success me-2" @onclick="GuardarRegistro">Guardar</button>
                <button class="btn btn-secondary" @onclick="Cancelar">Cancelar</button>
            </div>
        </div>
    }

    @* ───────── SPINNER ───────── *@
    @if (cargando)
    {
        <div class="d-flex justify-content-center my-4">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
        </div>
    }

    @* ───────── CONFIRMACIÓN DE ELIMINAR ───────── *@
    @if (confirmacion)
    {
        <div class="alert alert-warning d-flex justify-content-between align-items-center">

            <div>
                ¿Seguro que deseas eliminar el Area
                <strong>@nEliminar</strong>?
            </div>

            <div>
                <button class="btn btn-danger btn-sm"
                    @onclick="EliminarConfirmado">Si, Eliminar</button>
                <button class="btn btn-secondary btn-sm"
                    @onclick="CancelarEliminar">Cancelar</button>
            </div>

        </div>
    }

    @* ───────── TABLA ───────── *@
    @if (!cargando && registros.Any())
    {
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Codigo</th>
                    <th>Gran_Area</th>
                    <th>Area</th>
                    <th>Disciplina</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var reg in registros)
                {
                    <tr>
                        <td>@reg["id"]</td>
                        <td>@reg["gran_area"]</td>
                        <td>@reg["area"]</td>
                        <td>@reg["disciplina"]</td>
                        <td>
                            <button class="btn btn-warning btn-sm me-1"
                                    @onclick="() => EditarRegistro(reg)">Editar</button>
                            <button class="btn btn-danger btn-sm"
                                    @onclick="() => SolicitarEliminar(reg)">Eliminar</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }

    @if (!cargando && !registros.Any())
    {
        <div class="alert alert-warning">No se encontraron registros en la tabla areas.</div>
    }
</div>

@code {
    private List<Dictionary<string, object?>> registros = new();
    private bool cargando = true;
    private bool mostrarFormulario = false;
    private bool editando = false;
    private string mensaje = string.Empty;
    private bool exito = false;

    // Campos del formulario
    private string campoCodigo = string.Empty;
    private string campoGran = string.Empty;
    private string campoArea = string.Empty;
    private string campoDisc = string.Empty;
    private int? limite = null;

    // Campos Confirmación
    private bool confirmacion = false;
    private string idEliminar = string.Empty;
    private string nEliminar = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await CargarRegistros();
    }

    private async Task CargarRegistros()
    {
        cargando = true;
        registros = await Api.ListarAsync("area_conocimiento", limite);
        cargando = false;
    }

    private void NuevoRegistro()
    {
        editando = false;
        campoCodigo = string.Empty;
        campoGran = string.Empty;
        campoArea = string.Empty;
        campoDisc = string.Empty;
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private void EditarRegistro(Dictionary<string, object?> reg)
    {
        editando = true;
        campoCodigo = reg["id"]?.ToString() ?? "";
        campoGran = reg["gran_area"]?.ToString() ?? "";
        campoArea = reg["area"]?.ToString() ?? "";
        campoDisc = reg["disciplina"]?.ToString() ?? "";
        mostrarFormulario = true;
        mensaje = string.Empty;
    }

    private async Task GuardarRegistro()
    {
        var datos = new Dictionary<string, object?>
        {
            ["id"] = campoCodigo,
            ["gran_area"] = campoGran,
            ["area"] = campoArea,
            ["disciplina"] = campoDisc
        };

        if (editando)
        {
            datos.Remove("id");
            var resultado = await Api.ActualizarAsync("area_conocimiento", "id", campoCodigo, datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }
        else
        {
            var resultado = await Api.CrearAsync("area_conocimiento", datos);
            exito = resultado.exito;
            mensaje = resultado.mensaje;
        }

        if (exito)
        {
            mostrarFormulario = false;
            await CargarRegistros();
        }
    }

    private void SolicitarEliminar(Dictionary<string, object?> reg)
    {
        idEliminar = reg["id"]?.ToString() ?? "";
        nEliminar = reg["gran_area"]?.ToString() ?? "";
        confirmacion = true;
    }

    private async Task EliminarConfirmado()
    {
        var resultado = await Api.EliminarAsync("area_conocimiento", "id",idEliminar);

        exito = resultado.exito;
        mensaje = resultado.mensaje;

        confirmacion = false;

        if (exito)
            await CargarRegistros();
    }

    private async Task EliminarRegistro(Dictionary<string, object?> reg)
    {
        string codigo = reg["id"]?.ToString() ?? "";
        var resultado = await Api.EliminarAsync("area_conocimiento", "id", codigo);
        exito = resultado.exito;
        mensaje = resultado.mensaje;

        if (exito)
            await CargarRegistros();
    }

    private void Cancelar()
    {
        mostrarFormulario = false;
        mensaje = string.Empty;
    }

    private void CancelarEliminar()
    {
        confirmacion = false;
        mensaje = string.Empty;
    }
}
